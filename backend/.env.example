# Postgres runs on the Windows RTX PC, reached over Tailscale — not localhost.
#
# DATABASE_URL is the APPLICATION's runtime connection — must be a
# restricted role (NOSUPERUSER NOBYPASSRLS), never the admin/bootstrap
# role. Either one silently makes Row Level Security a no-op with no
# error (SCHEMA.md, Row Level Security — CRITICAL). Run migrations
# separately with the admin role's connection string (e.g.
# `DATABASE_URL=postgresql://odin:<pw>@<ip>:5432/odin sqlx migrate run`),
# never with this one.
DATABASE_URL=postgresql://odin_app:changeme@<windows-tailscale-ip>:5432/odin
DB_POOL_SIZE=10
PORT=8080

REDIS_URL=redis://<windows-tailscale-ip>:6379

# FastAPI AI service, also on the Windows RTX PC (Block 4/5).
AI_SERVICE_URL=http://<windows-tailscale-ip>:8000

# Generate with: openssl rand -hex 32 — never reuse the example below.
JWT_SECRET=<random-hex-secret>
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=30
OTP_EXPIRY_MINUTES=10
VERIFIED_SIGNUP_TOKEN_TTL_MINUTES=30
PASSWORD_MIN_LENGTH=12
# Optional — omit to use auth/email.rs's console-log stub sender
# instead of actually sending mail via Resend.
RESEND_API_KEY=
