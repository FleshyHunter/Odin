# Windows-side .env for docker-compose.windows.yml — gitignored, lives
# only on the Windows machine, never committed. This is the template;
# copy it to .env alongside docker-compose.windows.yml and fill in
# real values there.

# Admin/bootstrap "odin" Postgres role (docker-compose.windows.yml's
# own header comment). The restricted odin_app role used by
# backend/.env's DATABASE_URL is a separate, manual step.
POSTGRES_PASSWORD=changeme

# Block 10 (Dify) — one API key per Dify Workflow app (see
# ai_service/app/acquisition/ and its setup instructions). All
# optional: unset means /acquire, /generate_dag,
# /generate_exercise_template each return a clean 503 rather than
# ai_service failing to boot.
DIFY_BASE_URL=https://api.dify.ai
DIFY_ACQUIRE_API_KEY=
DIFY_DAG_API_KEY=
DIFY_EXERCISE_TEMPLATE_API_KEY=
